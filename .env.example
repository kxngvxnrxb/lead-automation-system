# =========================
# POSTGRES (SUPABASE)
# =========================
POSTGRES_HOST=your_postgres_host       # e.g., db.supabase.co
POSTGRES_DATABASE=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password

# =========================
# TELEGRAM
# =========================
TELEGRAM_APPROVAL_BOT_TOKEN=your_approval_bot_token
TELEGRAM_ERROR_BOT_TOKEN=your_error_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =========================
# GEMINI (AI / LLM)
# =========================
GEMINI_API_KEY=your_gemini_api_key

# =========================
# GMAIL (for sending emails)
# =========================
CLIENT_ID=your_gmail_client_id
CLIENT_SECRET=your_gmail_client_secret
REDIRECT_URI=your_gmail_redirect_uri
